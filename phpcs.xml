<?xml version="1.0"?>
<ruleset name="Checkout.com Pro for Gravity Forms">
	<description>WordPress Coding Standards for Checkout.com Pro plugin.</description>

	<rule ref="WordPress" />

	<file>.</file>

	<exclude-pattern>vendor/*</exclude-pattern>
	<exclude-pattern>node_modules/*</exclude-pattern>
	<exclude-pattern>build/*</exclude-pattern>

	<arg name="extensions" value="php" />

	<!--
		Gravity Forms GFPaymentAddOn base class REQUIRES protected properties
		to be prefixed with an underscore (e.g. $_slug, $_version, $_title).
		These are inherited API contracts - renaming them breaks the addon entirely.
		Sniff: PSR2.Classes.PropertyDeclaration.Underscore
	-->
	<rule ref="PSR2.Classes.PropertyDeclaration.Underscore">
		<exclude-pattern>includes/class-gf-checkout-com-pro-gateway.php</exclude-pattern>
	</rule>

	<!--
		base64_encode/decode is used for URL-safe return parameter encoding,
		not for obfuscation. This is a standard practice in GF payment addons.
	-->
	<rule ref="WordPress.PHP.DiscouragedPHPFunctions">
		<properties>
			<property name="exclude" type="array">
				<element value="obfuscation" />
			</property>
		</properties>
	</rule>

</ruleset>